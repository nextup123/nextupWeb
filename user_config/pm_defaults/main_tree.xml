<root main_tree_to_execute="MainTree" BTCPP_format="4">
  <include path="template.xml" />

  <BehaviorTree ID="MainTree">
    <Sequence name="MainSequence">
      <Start name="main_control_start_t">
        <Fallback name="MainFallback">

          <Sequence name="ControlSequence" ID="1">
            <SubTreePlus ID="main_tree" />
          </Sequence>
          
          <!-- ====================== SWITCH ON (expected_action="true") ====================== -->


          <!-- <Sequence name="ControlSequence" ID="1">
             <MsgLoggerNode name="ExitSequencelog" msg_log="Resetting the tree" />
          </Sequence> -->
          
          <Sequence name="ExitSequence">
            <MsgLoggerNode name="Exitmsglog" msg_log="entering into exit sequence the tree" />
            <MsgLoggerNode name="ExitSequencelog" msg_log="Resetting the tree" />
            <!-- <PublishDataOnTopic name="ExitSequencekill" type_of_topic="std_msgs/msg/String"
              msg_on_topic="stop" topic_name="/control_process_control_bt" /> -->
            <PublishDataOnTopic name="ExitSequenceReset" type_of_topic="std_msgs/msg/Bool"
              msg_on_topic="true" topic_name="/control_reset_bt" />
            <Sleep name="ExitSequenceSleep" msec="200" />
            <ResetTreeTrigger name="ExitSequenceResetting" />
          </Sequence>
        </Fallback>
      </Start>
    </Sequence>
  </BehaviorTree>
</root>
